# LLM (OpenAI-compatible — works with Ollama, LM Studio, Gemini, etc.)
LLM_MODEL=qwen2.5:7b-instruct
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434/v1

LLM_TEMPERATURE=0.5
LLM_MAX_TOKEN=256

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# Upload & chunking
UPLOAD_DIR=./uploads
MAX_CHUNK_SIZE=4000
CHUNK_OVERLAP=200
